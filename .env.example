# Default in supabase project
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required: Supabase Edge Function runtime secrets
GOOGLE_SERVICE_ACCOUNT_JSON=
GEMINI_API_KEY=

# Optional fallback only. OCR prefers GOOGLE_SERVICE_ACCOUNT_JSON.
GOOGLE_VISION_API_KEY=

# Required for public drug data sync
DATA_GO_KR_SERVICE_KEY=

# Optional runtime settings
GOOGLE_VISION_FEATURE=DOCUMENT_TEXT_DETECTION
GEMINI_MODEL=gemini-2.5-flash
DAILY_GOOGLE_OCR_LIMIT=50
DAILY_GEMINI_LIMIT=100

# Required only when FCM sending is enabled.
# If omitted, send-medication-reminders uses project_id from GOOGLE_SERVICE_ACCOUNT_JSON.
FCM_PROJECT_ID=
